# DeepSeek API — https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key

# Gmail sender credentials
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com
EMAIL_PASSWORD=your_gmail_app_password   # 16-char App Password (not your account password)

# Gmail SMTP (defaults work for Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Optional: SOCKS5 proxy (required if Gmail is blocked in your region, e.g. mainland China)
# Leave blank if you have direct access to Gmail
PROXY_HOST=127.0.0.1
PROXY_PORT=7890
